 [4]}}}, "documents": {"0": {"doc_id": 0, "url": "https://example.com/python-tutorial", "title": "Python Programming Tutorial for Beginners", "text": "Python is a high-level programming language known for its readability and simplicity. This Python tutorial covers Python basics including Python variables, Python data types. Python supports multiple programming paradigms including procedural, object-oriented. Python is widely used in web development, Python data science, machine learning. The Python ecosystem includes Python libraries: NumPy, Pandas, TensorFlow, Django. Python Python Python Python Python - this paragraph repeats Python many times to demonstrate that term frequency saturation works correctly with BM25 ranking.", "length": 65, "content_hash": "ad4ffa9014e04c22585a74e882cc3e34bc3d311efacd60702ff66cff18a8c914", "updated_at": 1781576132.2954607, "field_lengths": {"title": 4, "body": 65, "url": 5}, "field_term_freq": {"title": {"python": 1, "programming": 1, "tutorial": 1, "beginners": 1}, "body": {"python": 16, "high": 1, "level": 1, "programming": 2, "language": 1, "known": 1, "readability": 1, "simplicity": 1, "tutorial": 1, "covers": 1, "basics": 1, "including": 2, "variables": 1, "data": 2, "types": 1, "supports": 1, "multiple": 1, "paradigms": 1, "procedural": 1, "object": 1, "oriented": 1, "widely": 1, "used": 1, "web": 1, "development": 1, "science": 1, "machine": 1, "learning": 1, "ecosystem": 1, "includes": 1, "libraries": 1, "numpy": 1, "pandas": 1, "tensorflow": 1, "django": 1, "paragraph": 1, "repeats": 1, "many": 1, "times": 1, "demonstrate": 1, "term": 1, "frequency": 1, "saturation": 1, "works": 1, "correctly": 1, "bm25": 1, "ranking": 1}, "url": {"https": 1, "example": 1, "com": 1, "python": 1, "tutorial": 1}}}, "1": {"doc_id": 1, "url": "https://example.com/machine-learning", "title": "Introduction to Machine Learning with Python", "text": "Machine learning is a subset of artificial intelligence that enables systems to learn from data. Python is the most popular language for machine learning due to its rich ecosystem. Scikit-learn provides tools for machine learning data mining and analysis. TensorFlow and PyTorch are deep learning frameworks for machine learning neural networks. Machine learning algorithms: supervised machine learning, unsupervised machine learning.", "length": 44, "content_hash": "ed26002b2ee6f187d739eb5980dc10528594992d58760e6d9f8f745304e8a68c", "updated_at": 1781576132.2971978, "field_lengths": {"title": 4, "body": 44, "url": 5}, "field_term_freq": {"title": {"introduction": 1, "machine": 1, "learning": 1, "python": 1}, "body": {"machine": 7, "learning": 8, "subset": 1, "artificial": 1, "intelligence": 1, "enables": 1, "systems": 1, "learn": 2, "data": 2, "python": 1, "popular": 1, "language": 1, "due": 1, "rich": 1, "ecosystem": 1, "scikit": 1, "provides": 1, "tools": 1, "mining": 1, "analysis": 1, "tensorflow": 1, "pytorch": 1, "deep": 1, "frameworks": 1, "neural": 1, "networks": 1, "algorithms": 1, "supervised": 1, "unsupervised": 1}, "url": {"https": 1, "example": 1, "com": 1, "machine": 1, "learning": 1}}}, "2": {"doc_id": 2, "url": "https://example.com/data-science", "title": "Data Science and Analytics with Python", "text": "Data science combines statistics, programming, and domain knowledge to extract insights from data. Python is the primary language for data science with libraries like Pandas for data manipulation and Matplotlib for visualization. Data analysis involves data cleaning, exploratory analysis, and statistical modeling. Machine learning techniques are often used in data science for prediction and classification. Big data technologies like Apache Spark enable processing of large datasets. Data data data data science.", "length": 55, "content_hash": "666d5a392045c302c3a3a0d1aa3df7b588242d86c83153e3427480e7950589d8", "updated_at": 1781576132.2990453, "field_lengths": {"title": 4, "body": 55, "url": 5}, "field_term_freq": {"title": {"data": 1, "science": 1, "analytics": 1, "python": 1}, "body": {"data": 12, "science": 4, "combines": 1, "statistics": 1, "programming": 1, "domain": 1, "knowledge": 1, "extract": 1, "insights": 1, "python": 1, "primary": 1, "language": 1, "libraries": 1, "like": 2, "pandas": 1, "manipulation": 1, "matplotlib": 1, "visualization": 1, "analysis": 2, "involves": 1, "cleaning": 1, "exploratory": 1, "statistical": 1, "modeling": 1, "machine": 1, "learning": 1, "techniques": 1, "often": 1, "used": 1, "prediction": 1, "classification": 1, "big": 1, "technologies": 1, "apache": 1, "spark": 1, "enable": 1, "processing": 1, "large": 1, "datasets": 1}, "url": {"https": 1, "example": 1, "com": 1, "data": 1, "science": 1}}}, "3": {"doc_id": 3, "url": "https://example.com/search-engine", "title": "How Search Engines Work: Crawling, Indexing, and Ranking", "text": "Search engines use web crawlers to discover and download web pages from the internet. The crawled pages are then processed to build an inverted index that maps terms to documents. When a user submits a query, the search engine retrieves relevant documents from the index and ranks them by relevance. BM25 is a popular ranking function that considers term frequency, document length, and inverse document frequency. Modern search engines also use machine learning for query understanding and result ranking. TF-IDF is a simpler approach that BM25 improves upon by incorporating document length normalization and saturation of term frequency. Search engine ranking uses BM25 algorithm.", "length": 72, "content_hash": "6aaea2df731a598b4e5044cb8597439955f0abb5a06ab221caef85c012ad6de9", "updated_at": 1781576132.3014235, "field_lengths": {"title": 6, "body": 72, "url": 5}, "field_term_freq": {"title": {"search": 1, "engines": 1, "work": 1, "crawling": 1, "indexing": 1, "ranking": 1}, "body": {"search": 4, "engines": 2, "use": 2, "web": 2, "crawlers": 1, "discover": 1, "download": 1, "pages": 2, "internet": 1, "crawled": 1, "processed": 1, "build": 1, "inverted"